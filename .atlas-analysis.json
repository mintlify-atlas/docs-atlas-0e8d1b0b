  "keyFeatures": [
    "Structured memory layer for LLMs with automatic capture and recall",
    "Advanced augmentation extracting facts, preferences, relationships, and events",
    "Multi-database support (SQLite, PostgreSQL, MySQL, MongoDB, CockroachDB, Oracle, OceanBase)",
    "LLM-agnostic integration (OpenAI, Anthropic, Google Gemini, xAI Grok, AWS Bedrock)",
    "Framework support for LangChain, Agno, and Pydantic AI",
    "Semantic search with intelligent memory ranking and decay",
    "Two deployment options: Memori Cloud (managed) and BYODB (self-hosted)",
    "Knowledge graph for entity relationships and contextual understanding",
    "Multi-user support with entity and process attribution",
    "Async memory processing with zero added latency"
  ],
  "publicApiSurface": [
    "Memori() - Main SDK class for Python",
    "Memori.attribution(entity_id, process_id) - Assign user and process IDs",
    "Memori.llm.register(client) - Register LLM client wrapper",
    "Memori.new_session() - Start new conversation session",
    "Memori.set_session(id) - Resume existing session",
    "Memori.recall(query, limit) - Manual memory retrieval",
    "Memori.embed_texts(texts) - Generate embeddings",
    "Memori.close() - Release database connections",
    "python -m memori setup - CLI setup wizard",
    "python -m memori quota - Check API quota",
    "python -m memori sign-up - Create API account",
    "@memorilabs/memori (TypeScript/npm) - TypeScript SDK package",
    "LangChain ChatBedrock integration",
    "Agno framework integration",
    "Pydantic AI integration"
  ]
